{% doc %}
  @prompt
    create a 4 slide carousel. each slide has image, h5 title, and description. 4 slides are visible at a time. make it responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.gap }}px;
    overflow: hidden;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-carousel-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-carousel-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-carousel-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-carousel-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-carousel-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-carousel-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-carousel-track-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-track-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-carousel-wrapper-{{ ai_gen_id }} {
      padding: 0 16px;
    }
  }
{% endstyle %}

<carousel-block-{{ ai_gen_id }}
  class="ai-carousel-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'slide_' | append: i | append: '_image'
          assign title_key = 'slide_' | append: i | append: '_title'
          assign description_key = 'slide_' | append: i | append: '_description'

          assign slide_image = block.settings[image_key]
          assign slide_title = block.settings[title_key]
          assign slide_description = block.settings[description_key]
        %}

        <div class="ai-carousel-slide-{{ ai_gen_id }}">
          <div class="ai-carousel-image-wrapper-{{ ai_gen_id }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 800 }}"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
              >
            {% else %}
              <div class="ai-carousel-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-carousel-content-{{ ai_gen_id }}">
            {% if slide_title != blank %}
              <h5 class="ai-carousel-title-{{ ai_gen_id }}">{{ slide_title }}</h5>
            {% endif %}

            {% if slide_description != blank %}
              <div class="ai-carousel-description-{{ ai_gen_id }}">{{ slide_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</carousel-block-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('carousel-block-{{ ai_gen_id }}', CarouselBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "4 slide carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between slides",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        },
        {
          "value": "4 / 3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16 / 9",
          "label": "Wide (16:9)"
        },
        {
          "value": "3 / 4",
          "label": "Portrait (3:4)"
        }
      ],
      "default": "4 / 3"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Slide 1"
    },
    {
      "type": "image_picker",
      "id": "slide_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "slide_1_title",
      "label": "Title",
      "default": "Slide 1 Title"
    },
    {
      "type": "textarea",
      "id": "slide_1_description",
      "label": "Description",
      "default": "This is the description for slide 1."
    },
    {
      "type": "header",
      "content": "Slide 2"
    },
    {
      "type": "image_picker",
      "id": "slide_2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "slide_2_title",
      "label": "Title",
      "default": "Slide 2 Title"
    },
    {
      "type": "textarea",
      "id": "slide_2_description",
      "label": "Description",
      "default": "This is the description for slide 2."
    },
    {
      "type": "header",
      "content": "Slide 3"
    },
    {
      "type": "image_picker",
      "id": "slide_3_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "slide_3_title",
      "label": "Title",
      "default": "Slide 3 Title"
    },
    {
      "type": "textarea",
      "id": "slide_3_description",
      "label": "Description",
      "default": "This is the description for slide 3."
    },
    {
      "type": "header",
      "content": "Slide 4"
    },
    {
      "type": "image_picker",
      "id": "slide_4_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "slide_4_title",
      "label": "Title",
      "default": "Slide 4 Title"
    },
    {
      "type": "textarea",
      "id": "slide_4_description",
      "label": "Description",
      "default": "This is the description for slide 4."
    }
  ],
  "presets": [
    {
      "name": "4 slide carousel"
    }
  ]
}
{% endschema %}
