{% doc %}
  @prompt
    create a 4 slide carousel. each slide has image, h5 title, and description. 3.5 slides are visible at a time. make it responsive., remove the card styling and the arrows. add dynamic content on the description, remove the card styling and the arrows. add dynamic content on the description, remove the card styling and the arrows. add dynamic content on the description, remove the card styling and the arrows. add dynamic content on the description, Change the image aspect ratio to 1:1, and set the title styling to H5. Slide is hidden if the dynamic content value is empty
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-container-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    overflow: hidden;
    padding: 40px 0;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.slide_gap }}px;
    padding: 0 20px;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - (3.5 * {{ block.settings.slide_gap }}px)) / 3.5);
    min-width: calc((100% - (3.5 * {{ block.settings.slide_gap }}px)) / 3.5);
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-carousel-slide-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-carousel-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-carousel-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-carousel-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-carousel-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-carousel-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    line-height: 1.3;
  }

  .ai-carousel-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - (2.5 * {{ block.settings.slide_gap }}px)) / 2.5);
      min-width: calc((100% - (2.5 * {{ block.settings.slide_gap }}px)) / 2.5);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - (1.5 * {{ block.settings.slide_gap }}px)) / 1.5);
      min-width: calc((100% - (1.5 * {{ block.settings.slide_gap }}px)) / 1.5);
    }

    .ai-carousel-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }

    .ai-carousel-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<carousel-component-{{ ai_gen_id }} class="ai-carousel-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'slide_' | append: i | append: '_image'
          assign title_key = 'slide_' | append: i | append: '_title'
          assign description_key = 'slide_' | append: i | append: '_description'
          
          assign slide_image = block.settings[image_key]
          assign slide_title = block.settings[title_key]
          assign slide_description = block.settings[description_key]
          
          assign has_content = false
          if slide_description != blank
            assign has_content = true
          endif
        %}
        
        {% if has_content %}
          <div class="ai-carousel-slide-{{ ai_gen_id }}">
            <div class="ai-carousel-image-wrapper-{{ ai_gen_id }}">
              {% if slide_image %}
                <img
                  src="{{ slide_image | image_url: width: 600 }}"
                  alt="{{ slide_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-carousel-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            
            <div class="ai-carousel-content-{{ ai_gen_id }}">
              {% if slide_title != blank %}
                <h5 class="ai-carousel-title-{{ ai_gen_id }}">{{ slide_title }}</h5>
              {% endif %}
              
              {% if slide_description != blank %}
                <div class="ai-carousel-description-{{ ai_gen_id }}">
                  {{ slide_description }}
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</carousel-component-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselComponent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-carousel-wrapper-{{ ai_gen_id }}');
        this.setupTouchScroll();
      }

      setupTouchScroll() {
        let isDown = false;
        let startX;
        let scrollLeft;

        this.wrapper.addEventListener('mousedown', (e) => {
          isDown = true;
          startX = e.pageX - this.wrapper.offsetLeft;
          scrollLeft = this.wrapper.scrollLeft;
          this.wrapper.style.cursor = 'grabbing';
        });

        this.wrapper.addEventListener('mouseleave', () => {
          isDown = false;
          this.wrapper.style.cursor = 'grab';
        });

        this.wrapper.addEventListener('mouseup', () => {
          isDown = false;
          this.wrapper.style.cursor = 'grab';
        });

        this.wrapper.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.wrapper.offsetLeft;
          const walk = (x - startX) * 2;
          this.wrapper.scrollLeft = scrollLeft - walk;
        });

        this.wrapper.style.cursor = 'grab';
      }
    }

    customElements.define('carousel-component-{{ ai_gen_id }}', CarouselComponent{{ ai_gen_id }});
  })();
</script>

