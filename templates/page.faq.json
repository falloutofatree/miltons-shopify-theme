            "accordion_row_XW8QKG": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Can I make a change to my order?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_TQUg3D": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Plans change—we get it! If your order hasn’t shipped yet, we’ll do our best to make updates. Just reach out right away, and we’ll pop into action! Once your order ships, we can’t make changes, and carriers charge a fee for address corrections. So double-check your info before checkout, and if something looks off—let us know ASAP!<br/><br/><a href=\"https://e3q1y7-wg.nyla.site/_web_preview/pages/contact-us\">Contact Us</a></p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
