              "settings": {
                "text": "<p>5. Cookies and Tracking Technologies</p>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "h4",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
